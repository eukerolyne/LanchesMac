@model Lanche

<div class="container">
    <div class="row">
        <div class="card">

            <div class="text-center">
                <img src="@Model.ImagemUrl" class="img-fluid" alt="" />
            </div>

            <div class="card-block">
                <h2 class="card-title">@Model.Nome</h2>
                <p class="card-text"><h5>@Model.DescricaoDetalhada</h5></p>

                <p class="btn btn-group aling-content-lg-end">
                    <a asp-controller="Lanche" asp-action="List" class="btn btn-outline-info">
                        Ver todos os lanches
                    </a>

                    <a asp-controller="CarrinhoCompra" asp-action="AdicionarItemNoCarrinho"
                       class="btn btn-outline-info" asp-route-produtoId="@Model.ProdutoId">
                        Incluir no Carrinho
                    </a>
                </p>
            </div>

        </div>
    </div>
</div>